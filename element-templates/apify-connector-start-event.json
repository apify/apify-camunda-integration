{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Apify Message Catch Event Connector",
  "id": "io.camunda.connector.inbound.Apify.v1:StartEvent",
  "version": 1,
  "description": "Creates an Apify webhook for completed Actor or task runs, receives event updates, and deletes the webhook on deactivation.",
  "documentationRef": "https://github.com/apify/apify-camunda-integration/blob/main/README.md#2-inbound-connector-start-event",
  "metadata": {
    "keywords": [
      "apify",
      "connector",
      "webhook",
      "inbound",
      "actor",
      "task"
    ]
  },
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:StartEvent"
  ],
  "elementType": {
    "value": "bpmn:StartEvent"
  },
  "groups": [
    {
      "id": "authentication",
      "label": "Authentication"
    },
    {
      "id": "resourceType",
      "label": "Resource type",
      "tooltip": "Learn more about Actors and webhooks in the <a href=\"https://docs.apify.com/academy/expert-scraping-with-apify/actors-webhooks\">documentation</a>."
    },
    {
      "id": "resourceConfig",
      "label": "Resource configuration"
    },
    {
      "id": "activation",
      "label": "Activation details"
    },
    {
      "id": "output",
      "label": "Output mapping"
    }
  ],
  "properties": [
    {
      "id": "authentication.token",
      "label": "Apify API token",
      "description": "Your Apify API token for authentication.",
      "type": "String",
      "feel": "optional",
      "group": "authentication",
      "binding": {
        "type": "zeebe:property",
        "name": "authentication.token"
      },
      "constraints": {
        "notEmpty": true
      },
      "placeholder": "apify_api_..."
    },
    {
      "id": "resourceType",
      "label": "Resource Type",
      "description": "The Apify resource type to monitor (Actor or task).",
      "type": "Dropdown",
      "group": "resourceType",
      "value": "actor",
      "choices": [
        {
          "name": "Actor",
          "value": "actor"
        },
        {
          "name": "Task",
          "value": "task"
        }
      ],
      "binding": {
        "type": "zeebe:property",
        "name": "resourceType"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "id": "resourceId.actor",
      "label": "Actor",
      "description": "Actor name or ID (e.g., 'apify/web-scraper' or 'E2jjCZBezvAZnX8Rb').",
      "type": "String",
      "feel": "optional",
      "group": "resourceConfig",
      "binding": {
        "type": "zeebe:property",
        "name": "resourceId"
      },
      "condition": {
        "property": "resourceType",
        "equals": "actor",
        "type": "simple"
      },
      "constraints": {
        "notEmpty": true
      },
      "placeholder": "author/actor-name"
    },
    {
      "id": "resourceId.task",
      "label": "Task",
      "description": "Task name or ID (e.g., 'username/my-task' or 'abc123DEF456').",
      "type": "String",
      "feel": "optional",
      "group": "resourceConfig",
      "binding": {
        "type": "zeebe:property",
        "name": "resourceId"
      },
      "condition": {
        "property": "resourceType",
        "equals": "task",
        "type": "simple"
      },
      "constraints": {
        "notEmpty": true
      },
      "placeholder": "author/task-name"
    },
    {
      "id": "context",
      "label": "Webhook ID",
      "description": "The unique identifier for this webhook endpoint (auto-generated).",
      "type": "String",
      "group": "activation",
      "binding": {
        "type": "zeebe:property",
        "name": "inbound.context"
      },
      "constraints": {
        "notEmpty": true
      },
      "generatedValue": {
        "type": "uuid"
      }
    },
    {
      "id": "activationCondition",
      "label": "Activation Condition",
      "description": "A FEEL expression to filter events (e.g., '=connectorData.status = \"SUCCEEDED\"'). Use this to only start processes for successful Actor runs, ignore failures, etc. Default: empty (process all events).",
      "type": "Text",
      "feel": "required",
      "group": "activation",
      "optional": true,
      "binding": {
        "type": "zeebe:property",
        "name": "activationCondition"
      },
      "placeholder": "connectorData.status = \"SUCCEEDED\""
    },
    {
      "id": "resultVariable",
      "label": "Result Variable",
      "description": "Variable name to store the webhook event data (includes eventType, runId, status, actorId, taskId, defaultDatasetId, and more).",
      "type": "String",
      "group": "output",
      "optional": true,
      "binding": {
        "type": "zeebe:property",
        "name": "resultVariable"
      },
      "placeholder": "webhookResponse"
    },
    {
      "id": "resultExpression",
      "label": "Result Expression",
      "description": "A FEEL expression to transform the webhook data before storing.",
      "type": "Text",
      "feel": "required",
      "group": "output",
      "optional": true,
      "binding": {
        "type": "zeebe:property",
        "name": "resultExpression"
      },
      "placeholder": "{ result: connectorData }"
    },
    {
      "value": "io.camunda:apify-inbound:1",
      "binding": {
        "type": "zeebe:property",
        "name": "inbound.type"
      },
      "type": "Hidden"
    }
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}