{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Apify Message Catch Event Connector",
  "id": "io.camunda.connector.inbound.Apify.v1:StartEvent",
  "version": 1,
  "description": "Creates an Apify webhook for completed Actor or task runs, receives event updates, and deletes the webhook on deactivation.",
  "documentationRef": "https://github.com/apify/apify-camunda-integration/blob/main/README.md#2-inbound-connector-start-event",
  "metadata": {
    "keywords": [
      "apify",
      "connector",
      "webhook",
      "inbound",
      "actor",
      "task"
    ]
  },
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:StartEvent"
  ],
  "elementType": {
    "value": "bpmn:StartEvent"
  },
  "groups": [
    {
      "id": "authentication",
      "label": "Authentication"
    },
    {
      "id": "trigger",
      "label": "Trigger configuration",
      "tooltip": "Learn more about trigger in the <a href=\"https://docs.apify.com/academy/expert-scraping-with-apify/actors-webhooks\">documentation</a>."
    },
    {
      "id": "activation",
      "label": "Activation condition"
    },
    {
      "id": "output",
      "label": "Output mapping"
    }
  ],
  "properties": [
    {
      "id": "token",
      "label": "Apify API token",
      "description": "Your Apify API token for authentication.",
      "type": "String",
      "feel": "optional",
      "group": "authentication",
      "binding": {
        "type": "zeebe:property",
        "name": "token"
      },
      "constraints": {
        "notEmpty": true
      },
      "placeholder": "apify_api_..."
    },
    {
      "id": "resourceType",
      "label": "Resource type",
      "description": "The Apify resource type to monitor (Actor or task).",
      "type": "Dropdown",
      "group": "trigger",
      "value": "actor",
      "choices": [
        {
          "name": "Actor",
          "value": "actor"
        },
        {
          "name": "Task",
          "value": "task"
        }
      ],
      "binding": {
        "type": "zeebe:property",
        "name": "resourceType"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "id": "resourceId",
      "label": "Resource identifier",
      "description": "The Actor or task identifier to monitor (e.g., 'E2jjCZBezvAZnX8Rb' or 'apify/hello-world').",
      "type": "String",
      "feel": "optional",
      "group": "trigger",
      "binding": {
        "type": "zeebe:property",
        "name": "resourceId"
      },
      "constraints": {
        "notEmpty": true
      },
      "placeholder": "author/actor-name"
    },
    {
      "id": "context",
      "label": "Webhook ID",
      "description": "The unique identifier for this webhook endpoint (auto-generated).",
      "type": "String",
      "group": "activation",
      "binding": {
        "type": "zeebe:property",
        "name": "inbound.context"
      },
      "constraints": {
        "notEmpty": true
      },
      "generatedValue": {
        "type": "uuid"
      }
    },
    {
      "id": "activationCondition",
      "label": "Activation condition",
      "description": "A FEEL expression to filter events (e.g., '=request.connectorData.status = \"SUCCEEDED\"'). Use this to only start processes for successful Actor runs, ignore failures, etc. Leave empty to process all events.",
      "type": "Text",
      "feel": "required",
      "group": "activation",
      "optional": true,
      "binding": {
        "type": "zeebe:property",
        "name": "activationCondition"
      },
      "placeholder": "=request.connectorData.status = \"SUCCEEDED\""
    },
    {
      "id": "resultVariable",
      "label": "Result variable",
      "description": "The name of the variable to store the webhook event data. The event includes: eventType, runId, status, actorId, taskId, defaultDatasetId, and more. See the documentation for the full list.",
      "type": "String",
      "group": "output",
      "optional": true,
      "binding": {
        "type": "zeebe:property",
        "name": "resultVariable"
      },
      "placeholder": "webhookResponse"
    },
    {
      "id": "resultExpression",
      "label": "Result expression",
      "description": "A FEEL expression to transform the webhook data before storing.",
      "type": "Text",
      "feel": "required",
      "group": "output",
      "optional": true,
      "binding": {
        "type": "zeebe:property",
        "name": "resultExpression"
      },
      "placeholder": "={ result: response }"
    },
    {
      "value": "io.camunda:apify-inbound:1",
      "binding": {
        "type": "zeebe:property",
        "name": "inbound.type"
      },
      "type": "Hidden"
    }
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}