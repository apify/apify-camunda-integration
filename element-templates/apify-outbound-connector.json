{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Apify Connector",
  "id": "io.camunda.connector.outbound.Apify.v1",
  "version": 1,
  "description": "Access Apify tools for web scraping, data extraction, and automation.",
  "metadata": {
    "keywords": ["apify", "connector", "actor"]
  },
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": ["bpmn:Task"],
  "elementType": { "value": "bpmn:ServiceTask" },
  "engines": { "camunda": "^8.3" },
  "groups": [
    { "id": "authentication", "label": "Authentication" },
    { "id": "operation", "label": "Operation" },
    { "id": "apifyRequestInput", "label": "Apify Request" },
    { "id": "output", "label": "Output mapping" },
    { "id": "error", "label": "Error handling" },
    { "id": "retries", "label": "Retries" }
  ],
  "properties": [
    {
      "value": "io.camunda:apify-outbound:1",
      "binding": {
        "property": "type",
        "type": "zeebe:taskDefinition"
      },
      "type": "Hidden"
    },
    {
      "id": "authentication.method",
      "label": "Authentication Method",
      "optional": false,
      "value": "token",
      "constraints": { "notEmpty": true },
      "group": "authentication",
      "binding": { "name": "authentication.method", "type": "zeebe:input" },
      "type": "Dropdown",
      "choices": [
        { "name": "API Token", "value": "token" },
        { "name": "OAuth2", "value": "oauth" }
      ]
    },
    {
      "id": "authentication.token",
      "label": "API Token",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "authentication",
      "binding": { "name": "authentication.token", "type": "zeebe:input" },
      "condition": {
        "property": "authentication.method",
        "equals": "token",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "operation.type",
      "label": "Operation",
      "description": "Operation to perform",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "operation",
      "binding": { "name": "operation.type", "type": "zeebe:input" },
      "type": "Dropdown",
      "choices": [
        { "name": "Run Actor", "value": "runActor" },
        { "name": "Run Task", "value": "runTask" },
        { "name": "Scrape Single URL", "value": "scrapeSingleUrl" },
        { "name": "Get Dataset Items", "value": "getDatasetItems" },
        {
          "name": "Get Key Value Store Record",
          "value": "getKeyValueStoreRecord"
        }
      ]
    },
    {
      "id": "apifyRequestInput.runActorInput.actorId",
      "label": "Actor ID",
      "description": "Actor ID or a tilde-separated owner's username and Actor name",
      "optional": false,
      "feel": "optional",
      "constraints": { "notEmpty": true },
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.actorId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runActorInput.inputJson",
      "label": "Input JSON",
      "description": "JSON string with actor input (optional)",
      "optional": true,
      "feel": "required",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.inputJson",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "Text"
    },
    {
      "id": "apifyRequestInput.runActorInput.waitForFinish",
      "label": "Wait for Finish",
      "description": "Whether to wait for the actor run to finish (optional)",
      "group": "apifyRequestInput",
      "value": true,
      "binding": {
        "name": "apifyRequestInput.runActorInput.waitForFinish",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "Boolean"
    },
    {
      "id": "apifyRequestInput.runActorInput.timeout",
      "label": "Timeout (seconds)",
      "description": "Timeout in seconds for the actor run (optional)",
      "optional": true,
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.timeout",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runActorInput.memory",
      "label": "Memory",
      "description": "Memory allocation for the actor run (optional)",
      "optional": true,
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.memory",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "Dropdown",
      "choices": [
        { "name": "128 MB", "value": "128" },
        { "name": "256 MB", "value": "256" },
        { "name": "512 MB", "value": "512" },
        { "name": "1024 MB (1 GB)", "value": "1024" },
        { "name": "2048 MB (2 GB)", "value": "2048" },
        { "name": "4096 MB (4 GB)", "value": "4096" },
        { "name": "8192 MB (8 GB)", "value": "8192" },
        { "name": "16384 MB (16 GB)", "value": "16384" },
        { "name": "32768 MB (32 GB)", "value": "32768" }
      ]
    },
    {
      "id": "apifyRequestInput.runActorInput.buildTag",
      "label": "Build Tag",
      "description": "Build tag to use (optional)",
      "optional": true,
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.buildTag",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runTaskInput.taskId",
      "label": "Task",
      "description": "Task identifier to run. Supply the Task ID or the Task's name (e.g., 'apify/my-task').",
      "optional": false,
      "feel": "optional",
      "constraints": { "notEmpty": true },
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.taskId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runTaskInput.inputJson",
      "label": "Override input",
      "optional": true,
      "description": "Optional: JSON object to override the task's pre-configured input.",
      "feel": "required",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.inputJson",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "Text"
    },
    {
      "id": "apifyRequestInput.runTaskInput.waitForFinish",
      "label": "Wait for Finish",
      "description": "Whether to wait for the task run to finish (optional)",
      "group": "apifyRequestInput",
      "value": true,
      "binding": {
        "name": "apifyRequestInput.runTaskInput.waitForFinish",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "Boolean"
    },
    {
      "id": "apifyRequestInput.runTaskInput.timeout",
      "label": "Timeout (seconds)",
      "description": "Timeout in seconds for the task run (optional)",
      "optional": true,
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.timeout",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runTaskInput.memory",
      "label": "Memory",
      "description": "Memory allocation for the task run (optional)",
      "optional": true,
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.memory",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "Dropdown",
      "choices": [
        { "name": "128 MB", "value": "128" },
        { "name": "256 MB", "value": "256" },
        { "name": "512 MB", "value": "512" },
        { "name": "1024 MB (1 GB)", "value": "1024" },
        { "name": "2048 MB (2 GB)", "value": "2048" },
        { "name": "4096 MB (4 GB)", "value": "4096" },
        { "name": "8192 MB (8 GB)", "value": "8192" },
        { "name": "16384 MB (16 GB)", "value": "16384" },
        { "name": "32768 MB (32 GB)", "value": "32768" }
      ]
    },
    {
      "id": "apifyRequestInput.runTaskInput.buildTag",
      "label": "Build Tag",
      "description": "Build tag to use (optional)",
      "optional": true,
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.buildTag",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.getDatasetItemsInput.datasetId",
      "label": "Dataset ID",
      "description": "Unique ID of the dataset to get items from",
      "feel": "optional",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getDatasetItemsInput.datasetId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getDatasetItems",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.getDatasetItemsInput.offset",
      "label": "Offset",
      "description": "Number of items to skip (for pagination)",
      "optional": true,
      "feel": "optional",
      "value": 0,
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getDatasetItemsInput.offset",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getDatasetItems",
        "type": "simple"
      },
      "type": "Number"
    },
    {
      "id": "apifyRequestInput.getDatasetItemsInput.limit",
      "label": "Limit",
      "description": "Maximum number of items to return (leave empty or 0 for no limit)",
      "optional": true,
      "feel": "optional",
      "value": 0,
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getDatasetItemsInput.limit",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getDatasetItems",
        "type": "simple"
      },
      "type": "Number"
    },
    {
      "id": "apifyRequestInput.scrapeSingleUrlInput.url",
      "label": "URL",
      "description": "URL to be scraped. Must start with http:// or https:// and be a valid URL.",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.scrapeSingleUrlInput.url",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "scrapeSingleUrl",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.scrapeSingleUrlInput.crawlerType",
      "label": "Crawler Type",
      "description": "Select the crawling engine",
      "group": "apifyRequestInput",
      "condition": {
        "property": "operation.type",
        "equals": "scrapeSingleUrl",
        "type": "simple"
      },
      "binding": {
        "name": "apifyRequestInput.scrapeSingleUrlInput.crawlerType",
        "type": "zeebe:input"
      },
      "choices": [
        { "name": "Cheerio", "value": "cheerio" },
        { "name": "JSDOM", "value": "jsdom" },
        { "name": "Playwright Adaptive", "value": "playwright:adaptive" },
        { "name": "Playwright Firefox", "value": "playwright:firefox" }
      ],
      "value": "cheerio",
      "type": "Dropdown"
    },
    {
      "id": "apifyRequestInput.getKeyValueStoreRecordInput.storeId",
      "label": "Store ID",
      "description": "Unique ID of the key-value store",
      "optional": false,
      "constraints": { "notEmpty": true },
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getKeyValueStoreRecordInput.storeId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getKeyValueStoreRecord",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.getKeyValueStoreRecordInput.recordKey",
      "label": "Record Key",
      "description": "Key of the record to retrieve from the key-value store",
      "optional": false,
      "constraints": { "notEmpty": true },
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getKeyValueStoreRecordInput.recordKey",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getKeyValueStoreRecord",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "resultVariable",
      "label": "Result variable",
      "description": "Name of variable to store the response in",
      "group": "output",
      "binding": {
        "key": "resultVariable",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    },
    {
      "id": "resultExpression",
      "label": "Result expression",
      "description": "Expression to map the response into process variables",
      "feel": "required",
      "group": "output",
      "binding": {
        "key": "resultExpression",
        "type": "zeebe:taskHeader"
      },
      "type": "Text"
    },
    {
      "id": "errorExpression",
      "label": "Error expression",
      "description": "Expression to handle errors",
      "feel": "required",
      "group": "error",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      },
      "type": "Text"
    },
    {
      "id": "retryCount",
      "label": "Retries",
      "description": "Number of retries",
      "value": "3",
      "feel": "optional",
      "group": "retries",
      "binding": {
        "property": "retries",
        "type": "zeebe:taskDefinition"
      },
      "type": "String"
    },
    {
      "id": "retryBackoff",
      "label": "Retry backoff",
      "description": "ISO-8601 duration to wait between retries",
      "value": "PT0S",
      "group": "retries",
      "binding": {
        "key": "retryBackoff",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    }
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}
