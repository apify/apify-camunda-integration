{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Apify Connector",
  "id": "io.camunda.connector.outbound.Apify.v1",
  "version": 1,
  "description": "Access Apify tools for web scraping, data extraction, and automation.",
  "metadata": {
    "keywords": ["apify", "connector", "actor"]
  },
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": ["bpmn:Task"],
  "elementType": { "value": "bpmn:ServiceTask" },
  "engines": { "camunda": "^8.3" },
  "groups": [
    { "id": "authentication", "label": "Authentication" },
    { "id": "operation", "label": "Operation" },
    { "id": "apifyRequestInput", "label": "Apify Request" },
    { "id": "output", "label": "Output mapping" },
    { "id": "error", "label": "Error handling" },
    { "id": "retries", "label": "Retries" }
  ],
  "properties": [
    {
      "value": "io.camunda:apify-outbound:1",
      "binding": {
        "property": "type",
        "type": "zeebe:taskDefinition"
      },
      "type": "Hidden"
    },
    {
      "id": "authentication.method",
      "label": "Authentication Method",
      "optional": false,
      "value": "token",
      "constraints": { "notEmpty": true },
      "group": "authentication",
      "binding": { "name": "authentication.method", "type": "zeebe:input" },
      "type": "Dropdown",
      "choices": [
        { "name": "API Token", "value": "token" },
        { "name": "OAuth2", "value": "oauth" }
      ]
    },
    {
      "id": "authentication.token",
      "label": "API Token",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "authentication",
      "binding": { "name": "authentication.token", "type": "zeebe:input" },
      "condition": {
        "property": "authentication.method",
        "equals": "token",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "operation.type",
      "label": "Operation",
      "description": "Operation to perform",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "operation",
      "binding": { "name": "operation.type", "type": "zeebe:input" },
      "type": "Dropdown",
      "choices": [
        { "name": "Run Actor", "value": "runActor" },
        { "name": "Run Task", "value": "runTask" },
        { "name": "Scrape Single URL", "value": "scrapeSingleUrl" },
        { "name": "Get Dataset Items", "value": "getDatasetItems" },
        {
          "name": "Get Key Value Store Record",
          "value": "getKeyValueStoreRecord"
        }
      ]
    },
    {
      "id": "apifyRequestInput.runActorInput.actorId",
      "label": "Actor ID",
      "description": "Unique ID of the Actor to run",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.actorId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runTaskInput.taskId",
      "label": "Task ID",
      "description": "Unique ID of the Task to run",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.taskId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "resultVariable",
      "label": "Result variable",
      "description": "Name of variable to store the response in",
      "group": "output",
      "binding": {
        "key": "resultVariable",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    },
    {
      "id": "resultExpression",
      "label": "Result expression",
      "description": "Expression to map the response into process variables",
      "feel": "required",
      "group": "output",
      "binding": {
        "key": "resultExpression",
        "type": "zeebe:taskHeader"
      },
      "type": "Text"
    },
    {
      "id": "errorExpression",
      "label": "Error expression",
      "description": "Expression to handle errors",
      "feel": "required",
      "group": "error",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      },
      "type": "Text"
    },
    {
      "id": "retryCount",
      "label": "Retries",
      "description": "Number of retries",
      "value": "3",
      "feel": "optional",
      "group": "retries",
      "binding": {
        "property": "retries",
        "type": "zeebe:taskDefinition"
      },
      "type": "String"
    },
    {
      "id": "retryBackoff",
      "label": "Retry backoff",
      "description": "ISO-8601 duration to wait between retries",
      "value": "PT0S",
      "group": "retries",
      "binding": {
        "key": "retryBackoff",
        "type": "zeebe:taskHeader"
      },
      "type": "String"
    }
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}
