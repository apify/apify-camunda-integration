{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Apify Outbound Connector",
  "id": "io.camunda.connector.outbound.Apify.v1",
  "version": 1,
  "description": "Interacts with the Apify API to run Actors, tasks, scrape URLs, and more.",
  "metadata": {
    "keywords": ["apify", "connector", "actor"]
  },
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": ["bpmn:Task"],
  "elementType": { "value": "bpmn:ServiceTask" },
  "engines": { "camunda": "^8.3" },
  "groups": [
    { "id": "authentication", "label": "Authentication" },
    { "id": "operation", "label": "Operation" },
    { "id": "apifyRequestInput", "label": "Apify Request" },
    { "id": "output", "label": "Output mapping" },
    { "id": "error", "label": "Error handling" },
    { "id": "retries", "label": "Retries" }
  ],
  "properties": [
    {
      "value": "io.camunda:apify-outbound:1",
      "binding": {
        "property": "type",
        "type": "zeebe:taskDefinition"
      },
      "type": "Hidden"
    },
    {
      "id": "authentication.token",
      "label": "Apify API token",
      "description": "Your Apify API token for authentication.",
      "optional": false,
      "constraints": { "notEmpty": true },
      "feel": "optional",
      "group": "authentication",
      "binding": { "name": "authentication.token", "type": "zeebe:input" },
      "placeholder": "apify_api_...",
      "type": "String"
    },
    {
      "id": "operation.type",
      "label": "Operation",
      "description": "Operation to perform.",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "operation",
      "binding": { "name": "operation.type", "type": "zeebe:input" },
      "type": "Dropdown",
      "choices": [
        { "name": "Run Actor", "value": "runActor" },
        { "name": "Run task", "value": "runTask" },
        { "name": "Scrape single URL", "value": "scrapeSingleUrl" },
        { "name": "Get dataset items", "value": "getDatasetItems" },
        {
          "name": "Get key-value store record",
          "value": "getKeyValueStoreRecord"
        }
      ]
    },
    {
      "id": "apifyRequestInput.runActorInput.actorId",
      "label": "Actor",
      "description": "Actor name or ID (e.g., 'apify/web-scraper' or 'E2jjCZBezvAZnX8Rb').",
      "optional": false,
      "feel": "optional",
      "constraints": { "notEmpty": true },
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.actorId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "placeholder": "author/actor-name",
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runActorInput.inputJson",
      "label": "Input Body",
      "description": "JSON object for Actor input.",
      "optional": false,
      "constraints": { "notEmpty": true },
      "feel": "required",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.inputJson",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "placeholder": "={\"example\": \"value\"}",
      "type": "Text"
    },
    {
      "id": "apifyRequestInput.runActorInput.waitForFinish",
      "label": "Wait for Finish",
      "description": "Wait for the Actor run to complete.",
      "group": "apifyRequestInput",
      "value": true,
      "binding": {
        "name": "apifyRequestInput.runActorInput.waitForFinish",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "Boolean"
    },
    {
      "id": "apifyRequestInput.runActorInput.timeout",
      "label": "Timeout (seconds)",
      "description": "Maximum time in seconds for the Actor run to complete.",
      "optional": true,
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.timeout",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "placeholder": "60",
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runActorInput.memory",
      "label": "Memory (MB)",
      "description": "Memory allocation in MB for the Actor run. Optional.",
      "optional": true,
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.memory",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "Dropdown",
      "choices": [
        { "name": "128 MB", "value": "128" },
        { "name": "256 MB", "value": "256" },
        { "name": "512 MB", "value": "512" },
        { "name": "1024 MB (1 GB)", "value": "1024" },
        { "name": "2048 MB (2 GB)", "value": "2048" },
        { "name": "4096 MB (4 GB)", "value": "4096" },
        { "name": "8192 MB (8 GB)", "value": "8192" },
        { "name": "16384 MB (16 GB)", "value": "16384" },
        { "name": "32768 MB (32 GB)", "value": "32768" }
      ]
    },
    {
      "id": "apifyRequestInput.runActorInput.buildTag",
      "label": "Build",
      "description": "Actor build tag or ID (e.g., 'latest', '1.2.3'). Default: 'latest'.",
      "optional": true,
      "feel": "optional",
      "placeholder": "latest",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runActorInput.buildTag",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runActor",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runTaskInput.taskId",
      "label": "Task",
      "description": "Task name or ID (e.g., 'username/my-task' or 'abc123DEF456').",
      "optional": false,
      "feel": "optional",
      "constraints": { "notEmpty": true },
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.taskId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "placeholder": "author/task-name",
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runTaskInput.inputJson",
      "label": "Input Override",
      "description": "JSON object to override the task's default input. Optional.",
      "optional": true,
      "feel": "required",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.inputJson",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "placeholder": "={\"example\": \"value\"}",
      "type": "Text"
    },
    {
      "id": "apifyRequestInput.runTaskInput.waitForFinish",
      "label": "Wait for Finish",
      "description": "Wait for the task run to complete.",
      "group": "apifyRequestInput",
      "value": true,
      "binding": {
        "name": "apifyRequestInput.runTaskInput.waitForFinish",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "Boolean"
    },
    {
      "id": "apifyRequestInput.runTaskInput.timeout",
      "label": "Timeout (seconds)",
      "description": "Maximum time in seconds for the task run to complete.",
      "optional": true,
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.timeout",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "placeholder": "60",
      "type": "String"
    },
    {
      "id": "apifyRequestInput.runTaskInput.memory",
      "label": "Memory (MB)",
      "description": "Memory allocation in MB for the task run. Optional.",
      "optional": true,
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.memory",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "Dropdown",
      "choices": [
        { "name": "128 MB", "value": "128" },
        { "name": "256 MB", "value": "256" },
        { "name": "512 MB", "value": "512" },
        { "name": "1024 MB (1 GB)", "value": "1024" },
        { "name": "2048 MB (2 GB)", "value": "2048" },
        { "name": "4096 MB (4 GB)", "value": "4096" },
        { "name": "8192 MB (8 GB)", "value": "8192" },
        { "name": "16384 MB (16 GB)", "value": "16384" },
        { "name": "32768 MB (32 GB)", "value": "32768" }
      ]
    },
    {
      "id": "apifyRequestInput.runTaskInput.buildTag",
      "label": "Build",
      "description": "Build tag or ID (e.g., 'latest', '1.2.3'). Default: 'latest'.",
      "optional": true,
      "feel": "optional",
      "placeholder": "latest",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.runTaskInput.buildTag",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "runTask",
        "type": "simple"
      },
      "type": "String"
    },
    {
      "id": "apifyRequestInput.getDatasetItemsInput.datasetId",
      "label": "Dataset",
      "description": "The unique identifier of the dataset to retrieve items from.",
      "feel": "optional",
      "optional": false,
      "constraints": { "notEmpty": true },
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getDatasetItemsInput.datasetId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getDatasetItems",
        "type": "simple"
      },
      "placeholder": "abc123DEF456",
      "type": "String"
    },
    {
      "id": "apifyRequestInput.getDatasetItemsInput.offset",
      "label": "Offset",
      "description": "Number of items to skip from the beginning. Default: 0.",
      "optional": true,
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getDatasetItemsInput.offset",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getDatasetItems",
        "type": "simple"
      },
      "type": "String",
      "feel": "optional",
      "placeholder": "0"
    },
    {
      "id": "apifyRequestInput.getDatasetItemsInput.limit",
      "label": "Limit",
      "description": "Maximum number of items to return. Default: no limit.",
      "optional": true,
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getDatasetItemsInput.limit",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getDatasetItems",
        "type": "simple"
      },
      "type": "String",
      "feel": "optional",
      "placeholder": "99"
    },
    {
      "id": "apifyRequestInput.scrapeSingleUrlInput.url",
      "label": "URL",
      "description": "The URL to scrape (must start with http:// or https://).",
      "optional": false,
      "constraints": { "notEmpty": true },
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.scrapeSingleUrlInput.url",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "scrapeSingleUrl",
        "type": "simple"
      },
      "placeholder": "https://example.com",
      "type": "String"
    },
    {
      "id": "apifyRequestInput.scrapeSingleUrlInput.crawlerType",
      "label": "Crawler Type",
      "description": "The type of crawler to use.",
      "group": "apifyRequestInput",
      "condition": {
        "property": "operation.type",
        "equals": "scrapeSingleUrl",
        "type": "simple"
      },
      "binding": {
        "name": "apifyRequestInput.scrapeSingleUrlInput.crawlerType",
        "type": "zeebe:input"
      },
      "choices": [
        { "name": "Cheerio", "value": "cheerio" },
        { "name": "JSDOM", "value": "jsdom" },
        { "name": "Playwright Adaptive", "value": "playwright:adaptive" },
        { "name": "Playwright Firefox", "value": "playwright:firefox" }
      ],
      "value": "cheerio",
      "type": "Dropdown"
    },
    {
      "id": "apifyRequestInput.getKeyValueStoreRecordInput.storeId",
      "label": "Key-Value Store",
      "description": "The unique identifier of the key-value store.",
      "optional": false,
      "constraints": { "notEmpty": true },
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getKeyValueStoreRecordInput.storeId",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getKeyValueStoreRecord",
        "type": "simple"
      },
      "placeholder": "abc123DEF456",
      "type": "String"
    },
    {
      "id": "apifyRequestInput.getKeyValueStoreRecordInput.recordKey",
      "label": "Key",
      "description": "The key name to retrieve from the store.",
      "optional": false,
      "constraints": { "notEmpty": true },
      "feel": "optional",
      "group": "apifyRequestInput",
      "binding": {
        "name": "apifyRequestInput.getKeyValueStoreRecordInput.recordKey",
        "type": "zeebe:input"
      },
      "condition": {
        "property": "operation.type",
        "equals": "getKeyValueStoreRecord",
        "type": "simple"
      },
      "placeholder": "OUTPUT",
      "type": "String"
    },
    {
      "id": "resultVariable",
      "label": "Result Variable",
      "description": "Variable name to store the response in.",
      "group": "output",
      "binding": {
        "key": "resultVariable",
        "type": "zeebe:taskHeader"
      },
      "placeholder": "resultVariable",
      "type": "String"
    },
    {
      "id": "resultExpression",
      "label": "Result Expression",
      "description": "A FEEL expression to map the response into process variables.",
      "feel": "required",
      "group": "output",
      "binding": {
        "key": "resultExpression",
        "type": "zeebe:taskHeader"
      },
      "placeholder": "={ result: response }",
      "type": "Text"
    },
    {
      "id": "errorExpression",
      "label": "Error Expression",
      "description": "A FEEL expression to handle errors.",
      "feel": "required",
      "group": "error",
      "binding": {
        "key": "errorExpression",
        "type": "zeebe:taskHeader"
      },
      "placeholder": "=if error.code = \"ACTOR_NOT_FOUND\" then null else error",
      "type": "Text"
    },
    {
      "id": "retryCount",
      "label": "Retries",
      "description": "The number of retry attempts.",
      "value": "3",
      "feel": "optional",
      "group": "retries",
      "binding": {
        "property": "retries",
        "type": "zeebe:taskDefinition"
      },
      "type": "String"
    },
    {
      "id": "retryBackoff",
      "label": "Retry Backoff",
      "description": "The ISO-8601 duration to wait between retry attempts. Default: 'PT0S'.",
      "value": "PT0S",
      "group": "retries",
      "binding": {
        "key": "retryBackoff",
        "type": "zeebe:taskHeader"
      },
      "placeholder": "PT5S",
      "type": "String"
    }
  ],
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  }
}
